server <- function(input, output, session) {
landscape_reactive <- reactive({
load_landscape(
"images/blobs.png",
scale = input$scale,
cellsize = input$cellsize
) |> basic_habitat_quality(threshold = input$threshold)
})
output$landPlot <- renderPlot({
visualise_landscape(landscape_reactive())
})
}
shinyApp(ui, server)
